{
  "name": "server",
  "type": "module",
  "scripts": {
    "dev": "pnpm run codegen && wrangler dev",
    "deploy": "pnpm run codegen && wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "codegen": "pnpm run cf-typegen && prisma generate",
    "test": "vitest run",
    "lint": "eslint . --config eslint.config.ts"
  },
  "dependencies": {
    "@clerk/backend": "^3.2.4",
    "@clerk/clerk-sdk-node": "^5.1.6",
    "@hono/clerk-auth": "^3.0.3",
    "@hono/zod-validator": "^0.8.0",
    "@prisma/adapter-d1": "^6.16.1",
    "@prisma/client": "^6.16.1",
    "@season-sprint/shared": "workspace:*",
    "dotenv": "^17.2.3",
    "hono": "^4.12.28",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "eslint": "^9.36.0",
    "globals": "^16.4.0",
    "jiti": "^2.6.1",
    "miniflare": "^4.20260317.3",
    "prisma": "^6.16.1",
    "typescript-eslint": "^8.45.0",
    "vitest": "^1.6.1",
    "wrangler": "^4.4.0"
  }
}
